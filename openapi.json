{
  "openapi": "3.1.0",
  "info": {
    "title": "Movie Picker",
    "description": "Приложение для выбора фильмов с рекомендациями на основе AI",
    "version": "1.0.0"
  },
  "paths": {
    "/api/movies": {
      "get": {
        "tags": [
          "movies"
        ],
        "summary": "Get Movies",
        "description": "Получить список всех фильмов",
        "operationId": "get_movies_api_movies_get",
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Фильтр по источнику: personal, top100, awards",
              "title": "Source"
            },
            "description": "Фильтр по источнику: personal, top100, awards"
          },
          {
            "name": "is_watched",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Фильтр по статусу просмотра",
              "title": "Is Watched"
            },
            "description": "Фильтр по статусу просмотра"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  },
                  "title": "Response Get Movies Api Movies Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "movies"
        ],
        "summary": "Add Movie",
        "description": "Добавить фильм в список.\nМожно указать название или IMDb ID (tt1234567).",
        "operationId": "add_movie_api_movies_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MovieCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/movies/{movie_id}": {
      "get": {
        "tags": [
          "movies"
        ],
        "summary": "Get Movie",
        "description": "Получить фильм по ID",
        "operationId": "get_movie_api_movies__movie_id__get",
        "parameters": [
          {
            "name": "movie_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Movie Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "movies"
        ],
        "summary": "Update Movie",
        "description": "Обновить статус фильма (отметить просмотренным)",
        "operationId": "update_movie_api_movies__movie_id__patch",
        "parameters": [
          {
            "name": "movie_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Movie Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MovieUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "movies"
        ],
        "summary": "Delete Movie",
        "description": "Удалить фильм из списка",
        "operationId": "delete_movie_api_movies__movie_id__delete",
        "parameters": [
          {
            "name": "movie_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Movie Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/movies/by-imdb/{imdb_id}": {
      "post": {
        "tags": [
          "movies"
        ],
        "summary": "Add Movie By Imdb Id",
        "description": "Добавить фильм по IMDb ID (используется для топ-100)",
        "operationId": "add_movie_by_imdb_id_api_movies_by_imdb__imdb_id__post",
        "parameters": [
          {
            "name": "imdb_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Imdb Id"
            }
          },
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "personal",
              "title": "Source"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/search": {
      "get": {
        "tags": [
          "search"
        ],
        "summary": "Search Movies",
        "description": "Поиск фильмов в OMDB по названию",
        "operationId": "search_movies_api_search_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Поисковый запрос",
              "title": "Q"
            },
            "description": "Поисковый запрос"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OMDBSearchResult"
                  },
                  "title": "Response Search Movies Api Search Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/recommend": {
      "post": {
        "tags": [
          "recommendations"
        ],
        "summary": "Get Recommendations",
        "description": "Получить рекомендации на основе свободного запроса.\nПримеры запросов:\n- \"что-то лёгкое\"\n- \"драма про семью\"\n- \"фильм с Бенедиктом Камбербэтчем\"\n- \"что-нибудь захватывающее, но не боевик\"",
        "operationId": "get_recommendations_api_recommend_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
