# Environment / secrets
.env
.env.save
.env.local
.env.*.local
venv/
__pycache__/
*.pyc

# Local databases (dev SQLite — never commit; prod uses Postgres via DATABASE_URL).
# NOTE: backend/data/movies.db is already tracked — untrack it once with:
#   git rm --cached backend/data/movies.db
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Secrets — Instagram login cookies must never be committed
backend/data/instagram_cookies.txt

# Downloaded media / temp
backend/data/instagram_videos/
backend/data/instagram_tmp/

# Frontend build artifacts
frontend-new/node_modules/
frontend-new/dist/
frontend-new/*.mjs
frontend-new/tsconfig.tsbuildinfo

# Claude Code worktrees
.claude/worktrees/

# FUSE filesystem artifacts
backend/data/.fuse_hidden*

# one-off migration data (contains user data — do not commit)
telegram_migration_export.json
prod_backup_before_merge.json
