# OMDB API Key (получить на http://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here

# TMDB API Key (русскоязычный поиск фильмов; получить на
# https://www.themoviedb.org/settings/api). Если не задан — бот всё равно
# работает, просто кириллические запросы идут через OMDB + LLM-перевод.
TMDB_API_KEY=your_tmdb_api_key_here

# Google Books API Key — основной поиск книг (Open Library слабо знает русский).
# Опционально: без ключа работает анонимная квота. Получить в Google Cloud
# Console → APIs & Services → Credentials.
GOOGLE_BOOKS_API_KEY=

# Anthropic API Key (получить на https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (Whisper + GPT для разбора Instagram-рилзов)
OPENAI_API_KEY=your_openai_api_key_here

# Apify API token (Instagram Scraper — https://console.apify.com/settings/integrations)
APIFY_TOKEN=your_apify_token_here
# (опционально) Какой именно Apify actor использовать. Дефолт — apify~instagram-scraper.
# APIFY_INSTAGRAM_ACTOR=apify~instagram-scraper

# Куда сохранять скачанные видео (не удаляются автоматически)
INSTAGRAM_VIDEO_DIR=backend/data/instagram_videos
# Telegram Bot Token (получить у @BotFather в Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Public URL of the deployed Mini-App (frontend). When set, the Save
# Confirmation card adds an inline "📖 Открыть в Lentochka" button that
# launches the Mini-App via Telegram WebAppInfo. Leave empty if users
# open the Mini-App only via BotFather's menu button.
MINI_APP_URL=

# Webhook mode (prod): public base URL of THIS service + a secret path segment.
# When both are set (with TELEGRAM_BOT_TOKEN), the bot runs inside the web
# process via webhook — no separate worker. Leave empty locally and run the
# bot with `python bot.py` (long-polling) instead.
PUBLIC_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=

# JWT секрет для подписи токенов (ОБЯЗАТЕЛЕН; `openssl rand -hex 32`).
# Без него приложение намеренно не стартует — раньше был небезопасный дефолт.
JWT_SECRET=
# Срок жизни JWT в днях
JWT_EXPIRES_DAYS=30

# Google OAuth Client ID (Web application, из Google Cloud Console)
# Тот же ID ставится и во фронте (VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Список origin'ов через запятую, которым разрешён CORS.
# Локально достаточно дефолта; на проде указать домен фронта.
# Пример: https://lentochka.up.railway.app,http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000

# Rate limiting включён по умолчанию. RATE_LIMIT_ENABLED=0 выключает его
# (используется в тестах; в проде трогать не нужно).
RATE_LIMIT_ENABLED=1
